author = {Groner, Raffaela and Svensson, Klara and Axelrod, Drake and Khojah, Ranim and Mohamad, Mazen and Wohlrab, Rebekka},
title = {Empowering Software Engineers to Design More Secure Web Applications: Guidelines and Potential of Using LLMs as a Recommender Tool},
